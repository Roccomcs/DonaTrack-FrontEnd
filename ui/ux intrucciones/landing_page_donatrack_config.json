{
  "project": {
    "name": "DonaTrack Landing Page",
    "version": "1.0.0",
    "description": "Landing page para plataforma de donaciones transparentes con seguimiento fotográfico verificado",
    "type": "React + TypeScript + Tailwind CSS",
    "created": "2026-04-07"
  },
  "agent_model": {
    "role": "Frontend Developer & UI/UX Designer",
    "context": "Figma Make - Web Application Builder",
    "capabilities": [
      "React component development",
      "Tailwind CSS styling",
      "Responsive design implementation",
      "Image optimization",
      "Accessibility implementation"
    ]
  },
  "requirements": {
    "functional": [
      {
        "id": "REQ-001",
        "title": "Presentación del propósito",
        "description": "Mostrar el propósito y objetivos de DonaTrack de manera clara y atractiva",
        "priority": "high",
        "implemented": true
      },
      {
        "id": "REQ-002",
        "title": "Donaciones destacadas",
        "description": "Mostrar ejemplos de donaciones realizadas en el último mes con imágenes y detalles",
        "priority": "high",
        "implemented": true
      },
      {
        "id": "REQ-003",
        "title": "Galería pública",
        "description": "Visualización de fotos de donaciones entregadas sin necesidad de login",
        "priority": "high",
        "implemented": true
      },
      {
        "id": "REQ-004",
        "title": "Enlaces de acceso",
        "description": "Enlaces de registro e inicio de sesión para donantes y beneficiarios",
        "priority": "high",
        "implemented": true
      },
      {
        "id": "REQ-005",
        "title": "Información legal",
        "description": "Incluir enlaces a términos de servicio, política de privacidad y aviso legal",
        "priority": "medium",
        "implemented": true
      }
    ],
    "non_functional": [
      {
        "id": "NFR-001",
        "title": "Responsive Design",
        "description": "La landing page debe ser completamente responsive (móvil, tablet, desktop)",
        "implemented": true
      },
      {
        "id": "NFR-002",
        "title": "Performance",
        "description": "Carga rápida de imágenes con lazy loading",
        "implemented": true
      },
      {
        "id": "NFR-003",
        "title": "Accesibilidad",
        "description": "Uso correcto de atributos alt en imágenes y estructura semántica HTML",
        "implemented": true
      }
    ]
  },
  "technology_stack": {
    "frontend": {
      "framework": "React",
      "version": "^18.x",
      "language": "TypeScript"
    },
    "styling": {
      "framework": "Tailwind CSS",
      "version": "^4.x",
      "approach": "Utility-first CSS"
    },
    "icons": {
      "library": "lucide-react",
      "usage": "SVG React components"
    },
    "build_tool": {
      "name": "Vite",
      "version": "^5.x"
    },
    "package_manager": "pnpm"
  },
  "file_structure": {
    "src": {
      "app": {
        "App.tsx": "Componente principal con toda la landing page",
        "components": {
          "figma": {
            "ImageWithFallback.tsx": "Componente reutilizable para imágenes con fallback"
          }
        }
      },
      "styles": {
        "theme.css": "Variables CSS y tokens de diseño",
        "fonts.css": "Importaciones de fuentes personalizadas"
      }
    }
  },
  "components": {
    "App": {
      "type": "Page Component",
      "path": "/src/app/App.tsx",
      "description": "Componente principal que contiene toda la landing page",
      "sections": [
        {
          "name": "Header",
          "type": "Navigation",
          "sticky": true,
          "elements": ["Logo", "Navigation Menu", "Login Button", "Register Button"]
        },
        {
          "name": "Hero Section",
          "type": "Hero",
          "elements": ["Title", "Subtitle", "CTA Buttons", "Statistics", "Hero Image"]
        },
        {
          "name": "Purpose Section",
          "type": "Features",
          "elements": [
            {
              "title": "Transparencia Total",
              "icon": "CheckCircle",
              "description": "Seguimiento en tiempo real de cada donación"
            },
            {
              "title": "Conexión Directa",
              "icon": "Users",
              "description": "Sin intermediarios innecesarios"
            },
            {
              "title": "Verificación Fotográfica",
              "icon": "Camera",
              "description": "Documentación de cada entrega"
            }
          ]
        },
        {
          "name": "Featured Donations",
          "type": "Card Grid",
          "grid": "3 columns",
          "elements": ["Donation Cards"]
        },
        {
          "name": "Photo Gallery",
          "type": "Image Grid",
          "grid": "4 columns",
          "elements": ["Photo Items with Hover Effect"]
        },
        {
          "name": "CTA Section",
          "type": "Call to Action",
          "background": "gradient",
          "elements": ["Title", "Description", "Register Buttons"]
        },
        {
          "name": "Footer",
          "type": "Footer",
          "columns": 4,
          "elements": ["Branding", "Quick Links", "Access Links", "Contact Info", "Legal Links"]
        }
      ]
    },
    "ImageWithFallback": {
      "type": "Utility Component",
      "path": "/src/app/components/figma/ImageWithFallback.tsx",
      "description": "Componente para imágenes con carga lazy y manejo de errores",
      "props": {
        "src": {
          "type": "string",
          "required": true,
          "description": "URL de la imagen"
        },
        "alt": {
          "type": "string",
          "required": true,
          "description": "Texto alternativo para accesibilidad"
        },
        "className": {
          "type": "string",
          "required": false,
          "description": "Clases de Tailwind CSS"
        }
      }
    }
  },
